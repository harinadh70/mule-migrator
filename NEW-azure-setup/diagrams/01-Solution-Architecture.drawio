<mxfile>
  <diagram name="Solution Architecture" id="solution-arch">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Mule Migrator — Agentic AI Platform — Solution Architecture" style="text;html=1;fontSize=24;fontStyle=1;fillColor=none;align=center;verticalAlign=middle;fontColor=#1B365D;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="40" as="geometry"/>
        </mxCell>

        <!-- User Layer -->
        <mxCell id="user-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E8F0FE;strokeColor=#0070AD;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="1500" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="user-label" value="👤 Users &amp; Authentication" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;fontColor=#1B365D;" vertex="1" parent="1">
          <mxGeometry x="60" y="85" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="user1" value="Developer&#xa;(Browser)" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#0070AD;fontColor=#fff;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="110" width="80" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ad" value="Azure AD&#xa;(Entra ID)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0070AD;fontColor=#fff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="110" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="swa" value="Azure Static&#xa;Web App&#xa;(React 18 + TS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#12ABDB;fontColor=#fff;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="110" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="cdn" value="Azure CDN&#xa;(Global Edge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#12ABDB;fontColor=#fff;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="730" y="110" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Arrows user layer -->
        <mxCell id="a1" edge="1" source="user1" target="ad" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" edge="1" source="ad" target="swa" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" edge="1" source="swa" target="cdn" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Compute Layer -->
