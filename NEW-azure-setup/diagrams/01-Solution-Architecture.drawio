          <mxGeometry x="50" y="210" width="1500" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="compute-label" value="⚡ Serverless Compute (Azure Functions — Consumption Plan)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=none;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="60" y="215" width="500" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="func-http" value="HTTP Triggers&#xa;(15 endpoints)&#xa;━━━━━━━━━━━&#xa;POST /migrations&#xa;GET /migrations&#xa;GET /migrations/{id}&#xa;GET /files&#xa;GET /stats&#xa;POST /rag/search&#xa;POST /github/push" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6D00;fontColor=#fff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="245" width="180" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="func-queue" value="Queue Triggers&#xa;(Background Workers)&#xa;━━━━━━━━━━━━━&#xa;migration-queue&#xa;→ XML Parse&#xa;→ Static Engine&#xa;→ RAG Retrieval&#xa;→ GPT-4.1 Enhancement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF6D00;fontColor=#fff;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="245" width="200" height="130" as="geometry"/>
        </mxCell>

