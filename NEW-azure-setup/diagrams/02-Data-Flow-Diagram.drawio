        <!-- ========== SWIM LANE: AI ========== -->
        <mxCell id="lane-ai" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;dashed=0;opacity=40;" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="2120" height="200" as="geometry"/>
        </mxCell>
