        <mxCell id="ba4" value="Convert" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1B365D;fontColor=#1B365D;fontSize=9;fontStyle=1;strokeWidth=2;" edge="1" source="b4" target="b5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ba5" value="Generate" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1B365D;fontColor=#1B365D;fontSize=9;fontStyle=1;strokeWidth=2;" edge="1" source="b5" target="b6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
