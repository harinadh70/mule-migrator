        <mxCell id="aia2" value="Context + Files" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;fontColor=#7B1FA2;fontSize=9;fontStyle=1;strokeWidth=2;" edge="1" source="ai2" target="ai3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="aia3" value="Enhanced" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;fontColor=#7B1FA2;fontSize=9;fontStyle=1;strokeWidth=2;" edge="1" source="ai3" target="ai4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="aia4" value="Log" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;fontColor=#7B1FA2;fontSize=9;fontStyle=1;strokeWidth=1;" edge="1" source="ai3" target="ai5" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
