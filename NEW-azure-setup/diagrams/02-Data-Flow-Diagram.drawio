        <!-- AI nodes -->
        <mxCell id="ai1" value="RAG Retriever Agent&#xa;---&#xa;Input: parsed XML context&#xa;Query embedding (ada-002)&#xa;Cosine similarity search&#xa;Top-5 relevant docs&#xa;---&#xa;Output: knowledge context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#FFFFFF;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="790" width="210" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="ai2" value="pgvector DB&#xa;---&#xa;31 knowledge documents&#xa;1536-dim embeddings&#xa;Categories:&#xa;  mulesoft (8)&#xa;  dataweave (6)&#xa;  connector (10)&#xa;  best-practice (7)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#CE93D8;fontColor=#000000;fontSize=10;align=left;spacingLeft=10;size=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="780" width="190" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="ai3" value="Azure OpenAI GPT-4.1&#xa;(Singapore region)&#xa;---&#xa;System prompt + context&#xa;+ RAG knowledge&#xa;+ 21 generated files&#xa;---&#xa;Reviews &amp; enhances code&#xa;Fixes compilation issues&#xa;Adds best practices" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6A1B9A;fontColor=#FFFFFF;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="780" width="210" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="ai4" value="Enhanced Java Files&#xa;---&#xa;AI-reviewed code&#xa;Best practices applied&#xa;Error handling improved&#xa;Spring Boot idioms&#xa;---&#xa;Stored back in DB" style="shape=document;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1220" y="790" width="180" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="ai5" value="Agent Trace Log&#xa;---&#xa;Tokens: ~4K-12K&#xa;Cost: ~$0.02-0.08&#xa;Duration: 8-25s&#xa;Model: gpt-4.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#4A148C;fontColor=#FFFFFF;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1470" y="800" width="160" height="100" as="geometry"/>
