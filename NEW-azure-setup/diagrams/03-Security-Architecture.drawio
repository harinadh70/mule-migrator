        <mxCell id="lg4t" value="Monitoring" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="625" y="1313" width="80" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="lg5" value="" style="rounded=1;fillColor=none;strokeColor=#B71C1C;strokeWidth=2;dashed=1;" vertex="1" parent="1">
