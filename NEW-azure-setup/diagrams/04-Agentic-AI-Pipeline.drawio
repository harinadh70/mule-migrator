<mxfile>
  <diagram name="Agentic AI Pipeline" id="ai-pipeline">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Mule Migrator -- Agentic AI Platform -- Agentic AI Pipeline" style="text;html=1;fontSize=24;fontStyle=1;fillColor=none;align=center;verticalAlign=middle;fontColor=#1B365D;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="1200" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Detailed view of the AI agent orchestration pipeline with token costs and processing stages" style="text;html=1;fontSize=13;fillColor=none;align=center;verticalAlign=middle;fontColor=#666666;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="400" y="55" width="1200" height="25" as="geometry"/>
        </mxCell>

        <!-- ========== MAIN PIPELINE FLOW ========== -->

        <!-- Step 1: Input XML -->
        <mxCell id="input-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F57F17;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="250" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="input-header" value="INPUT" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#F57F17;fontColor=#FFFFFF;rounded=1;spacingLeft=8;spacingRight=8;align=center;" vertex="1" parent="1">
          <mxGeometry x="140" y="115" width="80" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="input-xml" value="MuleSoft XML File" style="shape=document;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F57F17;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="155" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="input-detail" value="Contains:&#xa;- Mule flows &amp; sub-flows&#xa;- HTTP listeners&#xa;- Connectors (DB, SFTP, etc.)&#xa;- DataWeave transforms&#xa;- Error handlers&#xa;- Global config&#xa;- Properties&#xa;---&#xa;Size: 1KB - 500KB&#xa;Encoding: UTF-8" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;align=left;spacingLeft=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="215" width="210" height="180" as="geometry"/>
        </mxCell>

        <!-- Step 2: Planner Agent -->
        <mxCell id="planner-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#283593;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="370" y="110" width="280" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="planner-header" value="AGENT 1: PLANNER" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#283593;fontColor=#FFFFFF;rounded=1;spacingLeft=8;spacingRight=8;align=center;" vertex="1" parent="1">
          <mxGeometry x="410" y="115" width="190" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="planner-icon" value="PLAN" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#283593;fontColor=#FFFFFF;fontSize=14;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="455" y="155" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="planner-inputs" value="Inputs:&#xa;- Raw XML content&#xa;- File metadata (name, size)&#xa;---&#xa;Processing:&#xa;1. Parse XML structure&#xa;2. Identify all flows&#xa;3. Map connectors&#xa;4. Detect DataWeave&#xa;5. Build migration plan&#xa;---&#xa;Outputs:&#xa;- MigrationPlan object&#xa;- Flow list + dependencies&#xa;- Connector inventory&#xa;---&#xa;Tokens: ~500-1,500&#xa;Cost: ~$0.001&#xa;Duration: &lt;1s (local)" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;align=left;spacingLeft=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="385" y="210" width="250" height="190" as="geometry"/>
        </mxCell>

        <!-- Step 3: Static Engine -->
        <mxCell id="static-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E0F2F1;strokeColor=#00695C;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="710" y="110" width="280" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="static-header" value="AGENT 2: STATIC ENGINE" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#00695C;fontColor=#FFFFFF;rounded=1;spacingLeft=8;spacingRight=8;align=center;" vertex="1" parent="1">
          <mxGeometry x="740" y="115" width="220" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="static-icon" value="BUILD" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#00695C;fontColor=#FFFFFF;fontSize=14;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="795" y="155" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="static-detail" value="Inputs:&#xa;- MigrationPlan from Planner&#xa;- Parsed flow objects&#xa;---&#xa;Processing:&#xa;1. FlowConverter&#xa;   (flow -&gt; REST controller)&#xa;2. ConnectorMapper&#xa;   (Mule -&gt; Spring deps)&#xa;3. DataWeaveConverter&#xa;   (DW -&gt; Java streams)&#xa;4. SpringBootGenerator&#xa;   (full project scaffold)&#xa;---&#xa;Outputs: 21 files&#xa;  pom.xml, Application.java,&#xa;  Controllers, Services,&#xa;  Models, Config, Tests,&#xa;  Dockerfile, README&#xa;---&#xa;Tokens: 0 (no AI)&#xa;Cost: $0.00&#xa;Duration: 1-3s" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;align=left;spacingLeft=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="725" y="205" width="250" height="200" as="geometry"/>
        </mxCell>

        <!-- Step 4: RAG Retriever -->
        <mxCell id="rag-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1050" y="110" width="280" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="rag-header" value="AGENT 3: RAG RETRIEVER" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#7B1FA2;fontColor=#FFFFFF;rounded=1;spacingLeft=8;spacingRight=8;align=center;" vertex="1" parent="1">
          <mxGeometry x="1080" y="115" width="220" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="rag-icon" value="RAG" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="1140" y="155" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="rag-detail" value="Inputs:&#xa;- Migration context summary&#xa;- Detected connectors list&#xa;- DataWeave expressions&#xa;---&#xa;Processing:&#xa;1. Generate query embedding&#xa;   (text-embedding-ada-002)&#xa;2. pgvector cosine search&#xa;3. Retrieve top-5 documents&#xa;4. Format as context block&#xa;---&#xa;Outputs:&#xa;- Relevant knowledge (5 docs)&#xa;- Source citations&#xa;- Relevance scores&#xa;---&#xa;Tokens: ~800-2,000&#xa;Cost: ~$0.0001 (embed)&#xa;Duration: 1-2s" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;align=left;spacingLeft=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1065" y="205" width="250" height="200" as="geometry"/>
        </mxCell>

        <!-- Step 5: AI Coder -->
        <mxCell id="coder-box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#FCE4EC;strokeColor=#C62828;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1390" y="110" width="300" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="coder-header" value="AGENT 4: AI CODER (GPT-4.1)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#C62828;fontColor=#FFFFFF;rounded=1;spacingLeft=8;spacingRight=8;align=center;" vertex="1" parent="1">
          <mxGeometry x="1410" y="115" width="260" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="coder-icon" value="AI" style="shape=hexagon;whiteSpace=wrap;html=1;fillColor=#C62828;fontColor=#FFFFFF;fontSize=14;fontStyle=1;size=0.15;" vertex="1" parent="1">
          <mxGeometry x="1490" y="155" width="100" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="coder-detail" value="Inputs:&#xa;- 21 generated Java files&#xa;- RAG knowledge context&#xa;- System prompt (best practices)&#xa;---&#xa;Processing (GPT-4.1):&#xa;1. Review all generated code&#xa;2. Fix compilation errors&#xa;3. Add proper error handling&#xa;4. Apply Spring Boot idioms&#xa;5. Improve DataWeave -&gt; Java&#xa;6. Add Javadoc comments&#xa;7. Optimize imports&#xa;---&#xa;Outputs:&#xa;- Enhanced Java files&#xa;- Change summary&#xa;- Confidence scores&#xa;---&#xa;Tokens: ~4,000-12,000&#xa;Cost: ~$0.02-$0.08&#xa;Duration: 8-25s" style="text;html=1;fontSize=10;fillColor=none;fontColor=#333;align=left;spacingLeft=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1405" y="205" width="270" height="200" as="geometry"/>
        </mxCell>

