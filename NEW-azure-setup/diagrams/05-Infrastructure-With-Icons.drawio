        <mxCell id="cost-table" value="&lt;table style='font-size:11px;border-collapse:collapse;width:100%'&gt;&#xa;&lt;tr style='background:#0070AD;color:white;font-weight:bold'&gt;&lt;td style='padding:6px;border:1px solid #ddd'&gt;Service&lt;/td&gt;&lt;td style='padding:6px;border:1px solid #ddd'&gt;SKU&lt;/td&gt;&lt;td style='padding:6px;border:1px solid #ddd'&gt;Monthly Cost&lt;/td&gt;&lt;td style='padding:6px;border:1px solid #ddd'&gt;Notes&lt;/td&gt;&lt;/tr&gt;&#xa;&lt;tr&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Azure Functions&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Consumption (Y1)&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd;color:#2E7D32;font-weight:bold'&gt;~$0-5&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;$0 when idle&lt;/td&gt;&lt;/tr&gt;&#xa;&lt;tr style='background:#f9f9f9'&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Static Web App&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Standard&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd;color:#2E7D32;font-weight:bold'&gt;$9&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Custom auth&lt;/td&gt;&lt;/tr&gt;&#xa;&lt;tr&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;PostgreSQL&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;B1ms + pgvector&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd;color:#2E7D32;font-weight:bold'&gt;$15&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Auto-stop when idle&lt;/td&gt;&lt;/tr&gt;&#xa;&lt;tr style='background:#f9f9f9'&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Redis Cache&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Basic C0&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd;color:#2E7D32;font-weight:bold'&gt;$15&lt;/td&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;250 MB&lt;/td&gt;&lt;/tr&gt;&#xa;&lt;tr&gt;&lt;td style='padding:5px;border:1px solid #ddd'&gt;Azure OpenAI&