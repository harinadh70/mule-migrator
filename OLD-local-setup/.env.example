# ═══════════════════════════════════════════════════════════════
#  MuleSoft to Spring Boot Migrator — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── App Settings ──────────────────────────────────────────────
FLASK_ENV=production
PORT=5000
SECRET_KEY=generate-a-random-secret-key-here
CORS_ORIGINS=*

# ── Gunicorn Settings ─────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# ── Nginx Settings (only if using with-nginx profile) ────────
NGINX_PORT=80
NGINX_SSL_PORT=443

# ── LLM API Keys (add the ones you use) ──────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
