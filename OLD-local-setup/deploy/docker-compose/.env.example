# =================================================================
#  Environment Variables — MuleSoft-to-SpringBoot Migrator
#  Copy to .env and fill in real values before deploying.
# =================================================================

# ── General ────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=CHANGE-ME-generate-a-64-char-random-string
LOG_LEVEL=info
CORS_ORIGINS=https://yourdomain.com

# ── API Server ─────────────────────────────────────────────────
API_PORT=8000
UVICORN_WORKERS=4

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=migrator
POSTGRES_PASSWORD=migrator_secret
POSTGRES_DB=migrator
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_DB=0
REDIS_CELERY_DB=1
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# ── Qdrant ─────────────────────────────────────────────────────
QDRANT_COLLECTION=mulesoft_knowledge
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ── Celery ─────────────────────────────────────────────────────
CELERY_MIGRATION_CONCURRENCY=2
CELERY_BUILD_CONCURRENCY=2
CELERY_INDEXING_CONCURRENCY=1

# ── LLM API Keys ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ── Embedding / RAG ───────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_ENABLED=true
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.65

# ── Feature Flags ──────────────────────────────────────────────
AGENTS_ENABLED=true

# ── Security ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=60
TRUSTED_HOSTS=*

# ── Nginx ──────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
